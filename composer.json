{
    "require": {
        "php": "^8.4",
        "vlucas/phpdotenv": "^5.6",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "slim/php-view": "^3.2",
        "php-di/php-di": "^7.0",
        "slim/twig-view": "^3.3",
        "slim/flash": "^0.4.0",
        "illuminate/database": "^11.0",
        "symfony/console": "^7.0",
        "fakerphp/faker": "^1.14"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "lint": "phpcs --standard=PSR12 src",
        "lint-fix": "phpcbf --standard=PSR12 src",
        "phpstan": "phpstan analyse src"
    }
}
